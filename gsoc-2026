# --- Constants & Configuration ---
API_BASE = "https://summerofcode.withgoogle.com/api/program/2026/organizations/"
CACHE_DIR = os.path.expanduser("~/.gsoc_explorer")
CACHE_FILE = os.path.join(CACHE_DIR, "orgs_2026.json")
LOCAL_CACHE = ".gsoc_cache.json"
CACHE_TTL = 86400  # 24 hours
LOG_FILE = os.path.join(CACHE_DIR, "explorer.log")

# Setup logging
if not os.path.exists(CACHE_DIR):
    os.makedirs(CACHE_DIR)

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

console = Console()

class GSoCDataService:
    def __init__(self, cache_ttl: int = CACHE_TTL):
        self.cache_ttl = cache_ttl
        self.session = self._setup_session()

    def _setup_session(self) -> requests.Session:
        session = requests.Session()
        retry_strategy = Retry(
            total=3,
            backoff_factor=1,
            status_forcelist=[429, 500, 502, 503, 504],
        )
        adapter = HTTPAdapter(max_retries=retry_strategy)
        session.mount("https://", adapter)
        session.mount("http://", adapter)
        return session

    def fetch_data(self, force_refresh: bool = False) -> List[Dict[str, Any]]:
        """Fetch organizations with smart caching."""
        if not force_refresh:
            # Check for local cache first (pre-bundled data)
            if os.path.exists(LOCAL_CACHE):
                try:
                    with open(LOCAL_CACHE, 'r') as f:
                        logging.info("Using local cache file.")
                        return json.load(f)
                except (json.JSONDecodeError, IOError) as e:
                    logging.error(f"Failed to read local cache: {e}")
            
            # Check for home directory cache
            if self._is_cache_valid():
                try:
                    with open(CACHE_FILE, 'r') as f:
                        logging.info("Using valid home directory cache.")
                        return json.load(f)
                except (json.JSONDecodeError, IOError) as e:
                    logging.error(f"Failed to read home cache: {e}")

        return self._refresh_cache()

    def _is_cache_valid(self) -> bool:
        if not os.path.exists(CACHE_FILE):
            return False
        return (time.time() - os.path.getmtime(CACHE_FILE)) < self.cache_ttl

    def _refresh_cache(self) -> List[Dict[str, Any]]:
        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            transient=True,
        ) as progress:
            progress.add_task(description="Syncing GSoC 2026 Organizations...", total=None)
            try:
                logging.info(f"Fetching data from {API_BASE}")
                response = self.session.get(API_BASE, timeout=15)
                response.raise_for_status()
                data = response.json()
                
                # Robust validation: Ensure it's a list
                if not isinstance(data, list):
                    raise ValueError("API returned unexpected data format (not a list).")

                with open(CACHE_FILE, 'w') as f:
                    json.dump(data, f)
                
                logging.info(f"Successfully synced {len(data)} organizations.")
                return data
            except (requests.RequestException, ValueError) as e:
                logging.error(f"Sync Failed: {e}")
                console.print(f"[bold red]Sync Failed:[/bold red] {e}")
                
                # Fallback to any available cache
                for path in [CACHE_FILE, LOCAL_CACHE]:
                    if os.path.exists(path):
                        console.print(f"[yellow]Using stale cache from {path} for now...[/yellow]")
                        with open(path, 'r') as f:
                            return json.load(f)
                
                console.print("[bold red]Critical Error:[/bold red] No local data available and network fetch failed.")
                sys.exit(1)

service = GSoCDataService()

def find_org(query: str, data: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    """Helper to find organization by slug or URL."""
    org = next((o for o in data if o['slug'].lower() == query.lower()), None)
    if not org and (query.startswith('http') or 'github.com' in query):
        q = query.lower()
        org = next((o for o in data if q in o.get('website_url', '').lower() or 
                    q in o.get('source_code', '').lower()), None)
    return org

