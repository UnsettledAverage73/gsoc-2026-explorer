@cli.command(name="list")
@click.option('--tech', '-t', multiple=True, help='Filter by technology (multiple allowed).')
@click.option('--cat', '-c', multiple=True, help='Filter by category (multiple allowed).')
@click.option('--limit', '-l', default=50, help='Limit results shown (default 50).')
@click.option('--sort', '-s', type=click.Choice(['name', 'tech_count']), default='name', help='Sort order.')
def list_orgs(tech, cat, limit, sort):
    """📋 List organizations with advanced multi-filter support."""
    data = service.fetch_data()
    
    # Filtering logic
    filtered = []
    tech_set = {t.lower() for t in tech}
    cat_set = {c.lower() for c in cat}

    for org in data:
        org_techs = {t.lower() for t in org.get('tech_tags', [])}
        org_cats = {c.lower() for c in org.get('categories', [])}
        
        if tech_set and not tech_set.issubset(org_techs):
            continue
        if cat_set and not any(c in org_cats for c in cat_set):
            continue
        filtered.append(org)

    # Sorting
    if sort == 'tech_count':
        filtered.sort(key=lambda x: len(x.get('tech_tags', [])), reverse=True)
    else:
        filtered.sort(key=lambda x: x['name'].lower())

    # Display
    table = Table(title=f"GSoC 2026: {len(filtered)} Organizations Found", box=None)
    table.add_column("#", justify="right", style="dim")
    table.add_column("Organization Name", style="bold cyan")
    table.add_column("Primary Tech", style="green")
    table.add_column("Slug", style="magenta")

    for i, org in enumerate(filtered[:limit]):
        table.add_row(
            str(i+1),
            org['name'],
            ", ".join(org.get('tech_tags', [])[:3]),
            org['slug']
        )

    console.print(table)
    if len(filtered) > limit:
        console.print(f"[dim]... and {len(filtered) - limit} more. Use --limit to see more.[/dim]")

@cli.command()
@click.argument('query')
def search(query):
    """🔍 Deep search by name, tagline, tech, or URL."""
    data = service.fetch_data()
    query = query.lower()
    matches = [o for o in data if query in o['name'].lower() or 
               query in o.get('tagline', '').lower() or
               query in o.get('website_url', '').lower() or
               query in o.get('source_code', '').lower() or
               any(query in t.lower() for t in o.get('tech_tags', []))]

    if not matches:
        console.print(f"[bold red]No matches found for '{query}'.[/bold red]")
        return

    for org in matches:
        console.print(Panel(
            f"[bold]{org['name']}[/bold]\n[italic]{org.get('tagline', '')}[/italic]",
            subtitle=f"[bold magenta]{org['slug']}[/bold magenta]",
            border_style="cyan"
        ))

@cli.command()
@click.argument('query')
def info(query):
    """ℹ️ Get the complete dossier for an organization by slug or URL."""
    data = service.fetch_data()
    org = find_org(query, data)
    
    if not org:
        console.print(f"[bold red]Error:[/bold red] Could not find organization for '{query}'.")
        return

    # Header
    console.print("\n")
    console.print(Panel(
        f"[bold blue]{org['name'].upper()}[/bold blue]\n[italic white]{org.get('tagline', '')}[/italic white]",
        title="Organization Dossier", 
        border_style="blue"
    ))

    # Links
    links_table = Table(show_header=False, box=None)
    links_table.add_row("[bold yellow]🌐 Website:[/bold yellow]", org.get('website_url'))
    links_table.add_row("[bold yellow]💻 Source:[/bold yellow]", org.get('source_code'))
    links_table.add_row("[bold yellow]💡 Ideas:[/bold yellow]", f"[link={org.get('ideas_link')}]{org.get('ideas_link')}[/link]")
    links_table.add_row("[bold yellow]📖 Guidance:[/bold yellow]", org.get('contributor_guidance_url'))
    console.print(links_table)

