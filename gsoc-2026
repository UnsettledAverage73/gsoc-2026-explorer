    console.print(f"\n[bold green]Technologies:[/bold green] {', '.join(org.get('tech_tags', []))}")
    console.print(f"[bold green]Categories:[/bold green] {', '.join(org.get('categories', []))}")

    # Description
    console.print("\n[bold cyan underline]Mission Description:[/bold cyan underline]")
    console.print(Markdown(org.get('description', '') or 'No description provided.'))
    console.print("\n")

@cli.command()
def stats():
    """📊 View participation analytics."""
    data = service.fetch_data()
    techs = {}
    for org in data:
        for t in org.get('tech_tags', []):
            techs[t] = techs.get(t, 0) + 1
    
    top_techs = sorted(techs.items(), key=lambda x: x[1], reverse=True)[:10]
    
    table = Table(title="Top 10 Technologies in GSoC 2026", box=None)
    table.add_column("Technology", style="bold green")
    table.add_column("Count", style="bold yellow")
    
    for tech, count in top_techs:
        table.add_row(tech, str(count))
    
    console.print(table)
    console.print(f"\n[bold]Total Mentoring Organizations:[/bold] {len(data)}")

@cli.command()
@click.argument('query')
@click.option('--dir', '-d', help='Directory to clone into.')
def clone(query, dir):
    """📥 Fast-track contribution: Clone an organization\'s repository."""
    data = service.fetch_data()
    org = find_org(query, data)
    
    if not org:
        console.print(f"[bold red]Error:[/bold red] Could not find organization for '{query}'.")
        return

    source_url = org.get('source_code')
    if not source_url:
        console.print(f"[bold red]Error:[/bold red] {org['name']} does not have a source code link.")
        return

    if "github.com" not in source_url:
        console.print(f"[yellow]Warning:[/yellow] Source URL is not a GitHub link: [cyan]{source_url}[/cyan]")
        if not Confirm.ask("Do you want to try cloning it anyway?"):
            return

    # Robust repository detection
    parts = source_url.rstrip('/').split('/')
    if len(parts) <= 4 and "github.com" in source_url:
        console.print(f"[bold yellow]Wait![/bold yellow] The source URL [cyan]{source_url}[/cyan] looks like an organization profile, not a specific repository.")
        repo_suggestion = Prompt.ask("Please enter the specific repository URL or press Enter to skip", default="")
        if repo_suggestion:
            source_url = repo_suggestion
        else:
            return

    console.print(f"[bold green]Cloning {org['name']}...[/bold green]")
    target_dir = dir or org['slug']
    
    try:
        logging.info(f"Attempting to clone {source_url} into {target_dir}")
        subprocess.run(["git", "clone", source_url, target_dir], check=True)
        console.print(f"\n[bold green]✔ Successfully cloned {org['name']} into {target_dir}![/bold green]")
        console.print(f"[bold cyan]Next Steps:[/bold cyan]")
        console.print(f"1. cd {target_dir}")
        console.print(f"2. Read the contribution guidelines: {org.get('contributor_guidance_url')}")
    except subprocess.CalledProcessError as e:
        logging.error(f"Clone failed for {source_url}: {e}")
        console.print(f"[bold red]Clone failed with exit code {e.returncode}.[/bold red]")
    except FileNotFoundError:
        console.print("[bold red]Error:[/bold red] 'git' command not found. Please install git.")

@cli.command()
@click.argument('type', type=click.Choice(['tech', 'cat']))
@click.option('--top', '-n', default=20, help='Show top N tags.')
def tags(type, top):
    """🏷️ List available technologies or categories."""
    data = service.fetch_data()
    counts = {}
    field = 'tech_tags' if type == 'tech' else 'categories'
    
    for org in data:
        for t in org.get(field, []):
            counts[t] = counts.get(t, 0) + 1
            
    sorted_tags = sorted(counts.items(), key=lambda x: x[1], reverse=True)[:top]
    
    title = "Popular Technologies" if type == 'tech' else "Popular Categories"
    table = Table(title=f"{title} (Top {top})", box=None)
    table.add_column("Tag Name", style="bold cyan")
    table.add_column("Organizations", justify="right", style="green")
    
    for tag, count in sorted_tags:
        table.add_row(tag, str(count))
        
    console.print(table)

@cli.command()
@click.argument('query')
@click.option('--ideas', '-i', is_flag=True, help='Open the ideas list page.')
@click.option('--guide', '-g', is_flag=True, help='Open the contributor guidance page.')
@click.option('--source', '-s', is_flag=True, help='Open the source code repository.')
def open(query, ideas, guide, source):
    """🌐 Open organization links in your default web browser."""
    data = service.fetch_data()
    org = find_org(query, data)
    
    if not org:
        console.print(f"[bold red]Error:[/bold red] Could not find organization for '{query}'.")
        return

    url = org.get('website_url')
    if ideas: url = org.get('ideas_link')
    elif guide: url = org.get('contributor_guidance_url')
    elif source: url = org.get('source_code')
    
    if not url:
        console.print(f"[bold red]Error:[/bold red] Requested link not found for {org['name']}.")
        return
        
    console.print(f"[bold green]Opening:[/bold green] {url}")
    webbrowser.open(url)

@cli.command()
@click.option('--tech', '-t', multiple=True, help='Filter by tech.')
@click.option('--cat', '-c', multiple=True, help='Filter by category.')
@click.option('--format', '-f', type=click.Choice(['json', 'csv']), default='json')
@click.argument('output_file', type=click.Path())
def export(tech, cat, format, output_file):
    """📤 Export filtered organizations to JSON or CSV."""
    data = service.fetch_data()
    
    # Filtering (same as list)
    filtered = []
    tech_set = {t.lower() for t in tech}
    cat_set = {c.lower() for c in cat}

    for org in data:
        org_techs = {t.lower() for t in org.get('tech_tags', [])}
        org_cats = {c.lower() for c in org.get('categories', [])}
        if tech_set and not tech_set.issubset(org_techs): continue
        if cat_set and not any(c in org_cats for c in cat_set): continue
        filtered.append(org)

    if format == 'json':
        with open(output_file, 'w') as f:
            json.dump(filtered, f, indent=4)
    else:
        if not filtered:
            console.print("[yellow]No data to export.[/yellow]")
            return
        keys = filtered[0].keys()
        with open(output_file, 'w', newline='') as f:
            dict_writer = csv.DictWriter(f, fieldnames=keys)
            dict_writer.writeheader()
            dict_writer.writerows(filtered)
            
    console.print(f"[bold green]✔ Exported {len(filtered)} organizations to {output_file}[/bold green]")

